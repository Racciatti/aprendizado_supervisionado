# Carregamento das bibliotecas
library(mlbench)
library(tidyverse)
library(summarytools)
# Carregando o dataset
data(PimaIndiansDiabetes)
dados <- PimaIndiansDiabetes
# NĂşmero de observaĂ§Ăµes e variĂˇveis
dim(dados)
# Nomes das variĂˇveis
colnames(dados)
# Nomes das variĂˇveis
colnames(dados)
# instalar se precisar
install.packages("NHANES")
install.packages("ggplot2")
install.packages("dplyr")
# carregar
library(NHANES)
library(ggplot2)
library(dplyr)
data(NHANES)
# a - histograma
hist(NHANES$BMI, main="Histograma BMI", xlab="BMI")
hist(NHANES$BMI, breaks="Sturges", main="BMI - Sturges", xlab="BMI")
hist(NHANES$BMI, breaks="FD", main="BMI - Freedman-Diaconis", xlab="BMI")
boxplot(BMI ~ Gender, data = NHANES,
main = "BMI por GĂŞnero",
xlab = "GĂŞnero",
ylab = "BMI")
ggplot(NHANES, aes(x = Gender, y = BMI)) +
geom_violin(fill = "lightblue") +
labs(title = "DistribuiĂ§ĂŁo de BMI por GĂŞnero",
x = "GĂŞnero",
y = "BMI") +
theme_minimal()
# barras
# frequĂŞncia absoluta
freq <- table(NHANES$Education)
ggplot(NHANES, aes(x = Gender, y = BMI)) +
geom_violin(fill = "lightblue") +
labs(title = "DistribuiĂ§ĂŁo de BMI por GĂŞnero",
x = "GĂŞnero",
y = "BMI") +
theme_minimal()
# barras
# frequĂŞncia absoluta
freq <- table(NHANES$Education)
barplot(freq, main="EducaĂ§ĂŁo (freq absoluta)", las=2)
# frequĂŞncia relativa
freq_rel <- prop.table(freq)
barplot(freq_rel, main="EducaĂ§ĂŁo (freq relativa)", las=2)
# e - Tabela contingĂŞncia
tab <- table(NHANES$Diabetes, NHANES$Gender)
tab
prop.table(tab, margin = 1)
prop.table(tab, margin = 2)
barplot(tab, beside=TRUE, legend=TRUE,
main="Diabetes por GĂŞnero")
plot(NHANES$Height, NHANES$Weight,
main="Altura vs Peso",
xlab="Altura",
ylab="Peso")
ggplot(NHANES, aes(x = Height, y = Weight)) +
geom_point(alpha = 0.5) +
labs(title="Altura vs Peso") +
theme_minimal()
# g - mat dispersĂŁo
vars <- NHANES %>%
select(Age, BMI, TotChol, BPSysAve)
pairs(vars)
# g - mat dispersĂŁo
vars <- NHANES %>%
select(Age, BMI, TotChol, BPSysAve)
pairs(vars)
# h - valores faltantes
colMeans(is.na(NHANES[, c("BMI", "Age", "TotChol", "BPSysAve")]))
# h - valores faltantes
colMeans(is.na(NHANES[, c("BMI", "Age", "TotChol", "BPSysAve")]))
barplot(colMeans(is.na(NHANES)) ,
main="ProporĂ§ĂŁo de NA por variĂˇvel",
las=2)
barplot(colMeans(is.na(NHANES)) ,
main="ProporĂ§ĂŁo de NA por variĂˇvel",
las=2)
# e - Tabela contingĂŞncia
tab <- table(NHANES$Diabetes, NHANES$Gender)
tab
prop.table(tab, margin = 1)
prop.table(tab, margin = 2)
barplot(tab, beside=TRUE, legend=TRUE,
main="Diabetes por GĂŞnero")
